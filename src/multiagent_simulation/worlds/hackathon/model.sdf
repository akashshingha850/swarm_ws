<?xml version="1.0"?>
<!--
  Hackathon World — Nokia Arena, Tampere, Finland
  Mission: take off, fly north, identify fire + count people in window, RTH.

  Building south face at y=92.5 (facade panels).
  Window opening (x: -1.5..1.5, z: 4.75..7.25) is an actual gap in the south wall.
  Glass at y=92.46, people at y=92.75, fire particles at y=92.9.
-->
<sdf version="1.9">
  <world name="map">

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <plugin name='gz::sim::systems::Physics'          filename='gz-sim-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands'     filename='gz-sim-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='gz-sim-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact'          filename='gz-sim-contact-system'/>
    <plugin name='gz::sim::systems::Imu'              filename='gz-sim-imu-system'/>
    <plugin name='gz::sim::systems::AirPressure'      filename='gz-sim-air-pressure-system'/>
    <plugin name='gz::sim::systems::AirSpeed'         filename='gz-sim-air-speed-system'/>
    <plugin name='gz::sim::systems::ApplyLinkWrench'  filename='gz-sim-apply-link-wrench-system'/>
    <plugin name='gz::sim::systems::Magnetometer'     filename='gz-sim-magnetometer-system'/>
    <plugin name='gz::sim::systems::NavSat'           filename='gz-sim-navsat-system'/>
    <plugin name='gz::sim::systems::ParticleEmitter'  filename='gz-sim-particle-emitter-system'/>
    <plugin name='gz::sim::systems::Sensors'          filename='gz-sim-sensors-system'>
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- ================================================================ -->
    <!-- LIGHTING                                                          -->
    <!-- ================================================================ -->

    <light name="sun" type="directional">
      <pose>0 0 500 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.0</intensity>
      <direction>0.3 0.5 -0.8</direction>
      <diffuse>0.95 0.95 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>2000</range><linear>0</linear><constant>1</constant><quadratic>0</quadratic>
      </attenuation>
    </light>

    <!-- Warm fire glow cast outward through window -->
    <light name="fire_light" type="point">
      <pose>0 92.9 6 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>4.0</intensity>
      <diffuse>1.0 0.45 0.05 1</diffuse>
      <specular>1.0 0.3 0.0 1</specular>
      <attenuation>
        <range>35</range><linear>0.04</linear><constant>0.1</constant><quadratic>0.015</quadratic>
      </attenuation>
    </light>

    <scene>
      <ambient>0.45 0.45 0.45 1</ambient>
      <background>0.6 0.75 0.9 1</background>
      <sky></sky>
    </scene>

    <!-- ================================================================ -->
    <!-- GROUND                                                            -->
    <!-- ================================================================ -->

    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 -0.05 0 0 0</pose>
      <link name="link">
        <collision name="c">
          <geometry><box><size>2000 2000 0.1</size></box></geometry>
        </collision>
        <visual name="v">
          <geometry><box><size>2000 2000 0.1</size></box></geometry>
          <material>
            <ambient>0.38 0.42 0.30 1</ambient>
            <diffuse>0.38 0.42 0.30 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- LAUNCH PAD                                                        -->
    <!-- ================================================================ -->

    <model name="launch_pad">
      <static>true</static>
      <pose>0 0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="pad">
          <geometry><box><size>3 3 0.03</size></box></geometry>
          <material>
            <ambient>0.85 0.75 0.0 1</ambient>
            <diffuse>0.85 0.75 0.0 1</diffuse>
            <emissive>0.2 0.15 0.0 1</emissive>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>3 3 0.03</size></box></geometry>
        </collision>
      </link>
    </model>

    <model name="pad_h_bar">
      <static>true</static>
      <pose>0 0 0.06 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.4 0.35 0.02</size></box></geometry>
          <material>
            <ambient>0.0 0.0 0.0 1</ambient>
            <diffuse>0.0 0.0 0.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- BUILDING                                                          -->
    <!--   Main body: 20×14×12 at (0,100,6) → south face at y=93         -->
    <!--   South facade: 4 wall panels at y=92.5 (1 m thick)             -->
    <!--   Window opening: x ∈ [-1.5,1.5], z ∈ [4.75,7.25]             -->
    <!-- ================================================================ -->

    <!-- Main building body (no south face — covered by facade panels) -->
    <model name="building_body">
      <static>true</static>
      <pose>0 100 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20 14 12</size></box></geometry>
          <material>
            <ambient>0.65 0.62 0.58 1</ambient>
            <diffuse>0.65 0.62 0.58 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>20 14 12</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- South facade — below window (z: 0 → 4.75, centre z=2.375) -->
    <model name="sw_bottom">
      <static>true</static>
      <pose>0 92.5 2.375 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20 1.0 4.75</size></box></geometry>
          <material>
            <ambient>0.65 0.62 0.58 1</ambient>
            <diffuse>0.65 0.62 0.58 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>20 1.0 4.75</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- South facade — above window (z: 7.25 → 12, centre z=9.625) -->
    <model name="sw_top">
      <static>true</static>
      <pose>0 92.5 9.625 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20 1.0 4.75</size></box></geometry>
          <material>
            <ambient>0.65 0.62 0.58 1</ambient>
            <diffuse>0.65 0.62 0.58 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>20 1.0 4.75</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- South facade — left of window (x: -10 → -1.5, centre x=-5.75) -->
    <model name="sw_left">
      <static>true</static>
      <pose>-5.75 92.5 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>8.5 1.0 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.62 0.58 1</ambient>
            <diffuse>0.65 0.62 0.58 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>8.5 1.0 2.5</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- South facade — right of window (x: 1.5 → 10, centre x=5.75) -->
    <model name="sw_right">
      <static>true</static>
      <pose>5.75 92.5 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>8.5 1.0 2.5</size></box></geometry>
          <material>
            <ambient>0.65 0.62 0.58 1</ambient>
            <diffuse>0.65 0.62 0.58 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>8.5 1.0 2.5</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- WINDOW — transparent orange-glowing glass + dark frame bars      -->
    <!-- Glass at y=92.46 (just outside south facade face at y=92.0)     -->
    <!-- ================================================================ -->

    <!-- Glass pane — semi-transparent with fire glow -->
    <model name="window_glass">
      <static>true</static>
      <pose>0 92.44 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <transparency>0.45</transparency>
          <geometry><box><size>3.0 0.05 2.5</size></box></geometry>
          <material>
            <ambient>1.0 0.50 0.05 1</ambient>
            <diffuse>1.0 0.50 0.05 1</diffuse>
            <emissive>0.70 0.22 0.0 1</emissive>
            <specular>0.8 0.5 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Window frame — top bar -->
    <model name="wf_top">
      <static>true</static>
      <pose>0 92.41 7.32 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>3.24 0.12 0.14</size></box></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Window frame — bottom bar -->
    <model name="wf_bottom">
      <static>true</static>
      <pose>0 92.41 4.68 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>3.24 0.12 0.14</size></box></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Window frame — left bar -->
    <model name="wf_left">
      <static>true</static>
      <pose>-1.57 92.41 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.14 0.12 2.78</size></box></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Window frame — right bar -->
    <model name="wf_right">
      <static>true</static>
      <pose>1.57 92.41 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.14 0.12 2.78</size></box></geometry>
          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.15 0.15 0.15 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- FIRE — particle emitter inside window recess                     -->
    <!-- Base at (0, 92.9, 4.9) — fires particles upward (+z)            -->
    <!-- ================================================================ -->

    <model name="fire">
      <static>true</static>
      <pose>0 92.9 4.9 0 0 0</pose>
      <link name="link">

        <!-- Main flame: bright yellow-orange → dark red/transparent -->
        <particle_emitter name="flames" type="box">
          <emitting>true</emitting>
          <size>1.4 0.3 0.1</size>
          <particle_size>0.35 0.35 0.35</particle_size>
          <lifetime>1.4</lifetime>
          <min_velocity>0.7</min_velocity>
          <max_velocity>1.6</max_velocity>
          <scale_rate>0.9</scale_rate>
          <rate>40</rate>
          <color_start>1.0 0.85 0.0 1.0</color_start>
          <color_end>0.85 0.05 0.0 0.0</color_end>
          <particle_scatter_ratio>0.1</particle_scatter_ratio>
        </particle_emitter>

        <!-- Inner hot core: brighter, faster, smaller -->
        <particle_emitter name="core" type="box">
          <emitting>true</emitting>
          <size>0.7 0.2 0.05</size>
          <particle_size>0.22 0.22 0.22</particle_size>
          <lifetime>0.9</lifetime>
          <min_velocity>1.0</min_velocity>
          <max_velocity>2.2</max_velocity>
          <scale_rate>0.5</scale_rate>
          <rate>55</rate>
          <color_start>1.0 1.0 0.6 1.0</color_start>
          <color_end>1.0 0.4 0.0 0.0</color_end>
          <particle_scatter_ratio>0.1</particle_scatter_ratio>
        </particle_emitter>

        <!-- Smoke: dark gray rising above flame, offset z=2.2 -->
        <particle_emitter name="smoke" type="box">
          <pose>0 0 2.2 0 0 0</pose>
          <emitting>true</emitting>
          <size>1.2 0.3 0.1</size>
          <particle_size>0.55 0.55 0.55</particle_size>
          <lifetime>4.0</lifetime>
          <min_velocity>0.25</min_velocity>
          <max_velocity>0.55</max_velocity>
          <scale_rate>0.28</scale_rate>
          <rate>7</rate>
          <color_start>0.30 0.28 0.25 0.80</color_start>
          <color_end>0.50 0.50 0.50 0.0</color_end>
          <particle_scatter_ratio>0.05</particle_scatter_ratio>
        </particle_emitter>

      </link>
    </model>

    <!-- ================================================================ -->
    <!-- PEOPLE — 3 occupants visible through the fire window            -->
    <!-- Positioned at y=92.75 (inside window recess, in front of wall) -->
    <!-- Window recess: y ∈ [92.0, 93.0]                                -->
    <!-- ================================================================ -->

    <!-- Person 1 — left, blue jacket -->
    <model name="person1_body">
      <static>true</static>
      <pose>-0.85 92.75 5.55 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.55 0.32 1.65</size></box></geometry>
          <material>
            <ambient>0.10 0.20 0.80 1</ambient>
            <diffuse>0.10 0.20 0.80 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    <model name="person1_head">
      <static>true</static>
      <pose>-0.85 92.75 6.60 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><sphere><radius>0.19</radius></sphere></geometry>
          <material>
            <ambient>0.82 0.62 0.44 1</ambient>
            <diffuse>0.82 0.62 0.44 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Person 2 — right, red jacket -->
    <model name="person2_body">
      <static>true</static>
      <pose>0.85 92.75 5.55 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.55 0.32 1.65</size></box></geometry>
          <material>
            <ambient>0.82 0.10 0.10 1</ambient>
            <diffuse>0.82 0.10 0.10 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    <model name="person2_head">
      <static>true</static>
      <pose>0.85 92.75 6.60 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><sphere><radius>0.19</radius></sphere></geometry>
          <material>
            <ambient>0.74 0.54 0.40 1</ambient>
            <diffuse>0.74 0.54 0.40 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Person 3 — centre, crouching, green jacket -->
    <model name="person3_body">
      <static>true</static>
      <pose>0.0 92.82 5.10 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.55 0.32 1.05</size></box></geometry>
          <material>
            <ambient>0.12 0.60 0.18 1</ambient>
            <diffuse>0.12 0.60 0.18 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    <model name="person3_head">
      <static>true</static>
      <pose>0.0 92.82 5.78 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><sphere><radius>0.19</radius></sphere></geometry>
          <material>
            <ambient>0.66 0.50 0.32 1</ambient>
            <diffuse>0.66 0.50 0.32 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- SPHERICAL COORDINATES — Nokia Arena, Tampere, Finland           -->
    <!-- ================================================================ -->

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>61.4938</latitude_deg>
      <longitude_deg>23.7735</longitude_deg>
      <elevation>77.0</elevation>
      <heading_deg>0.0</heading_deg>
    </spherical_coordinates>

    <gravity>0.0 0.0 -9.81</gravity>

  </world>
</sdf>
