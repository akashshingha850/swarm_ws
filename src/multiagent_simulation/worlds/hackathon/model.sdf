<?xml version="1.0"?>
<!--
  Autonomous Surveillance and Rescue Challenge — Hackathon World
  Venue: Nokia Arena, Tampere, Finland

  Layout (ENU, all distances in metres):
    (0,0,0)    — drone launch / landing pad
    (0,100,6)  — building centre (3 floors, 12 m tall)
    (0,92.5,6) — south face / TARGET fire window (floor 2)

  Mission: take off, fly north, identify fire + count 3 people in window, RTH.
-->
<sdf version="1.9">
  <world name="map">

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ================================================================ -->
    <!-- LIGHTING                                                          -->
    <!-- ================================================================ -->

    <light name="sun" type="directional">
      <pose>0 0 500 0 -0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1.0</intensity>
      <direction>0.3 0.5 -0.8</direction>
      <diffuse>0.95 0.95 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

    <!-- Warm fire point-light visible from outside the window -->
    <light name="fire_light" type="point">
      <pose>0 93 6 0 0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>3.0</intensity>
      <diffuse>1.0 0.45 0.05 1</diffuse>
      <specular>1.0 0.3 0.0 1</specular>
      <attenuation>
        <range>30</range>
        <linear>0.05</linear>
        <constant>0.1</constant>
        <quadratic>0.02</quadratic>
      </attenuation>
    </light>

    <!-- ================================================================ -->
    <!-- PLUGINS                                                           -->
    <!-- ================================================================ -->

    <plugin name='gz::sim::systems::Physics'          filename='gz-sim-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands'     filename='gz-sim-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='gz-sim-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact'          filename='gz-sim-contact-system'/>
    <plugin name='gz::sim::systems::Imu'              filename='gz-sim-imu-system'/>
    <plugin name='gz::sim::systems::AirPressure'      filename='gz-sim-air-pressure-system'/>
    <plugin name='gz::sim::systems::AirSpeed'         filename='gz-sim-air-speed-system'/>
    <plugin name='gz::sim::systems::ApplyLinkWrench'  filename='gz-sim-apply-link-wrench-system'/>
    <plugin name='gz::sim::systems::Magnetometer'     filename='gz-sim-magnetometer-system'/>
    <plugin name='gz::sim::systems::NavSat'           filename='gz-sim-navsat-system'/>
    <plugin name='gz::sim::systems::Sensors'          filename='gz-sim-sensors-system'>
      <render_engine>ogre2</render_engine>
    </plugin>

    <scene>
      <ambient>0.45 0.45 0.45 1</ambient>
      <background>0.6 0.75 0.9 1</background>
      <sky></sky>
    </scene>

    <!-- ================================================================ -->
    <!-- GROUND                                                            -->
    <!-- ================================================================ -->

    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 -0.05 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>2000 2000 0.1</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>2000 2000 0.1</size></box></geometry>
          <material>
            <ambient>0.38 0.42 0.30 1</ambient>
            <diffuse>0.38 0.42 0.30 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Concrete apron around launch area -->
    <model name="concrete_apron">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>60 60 0.02</size></box></geometry>
          <material>
            <ambient>0.55 0.55 0.55 1</ambient>
            <diffuse>0.55 0.55 0.55 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- LAUNCH / LANDING PAD  (H marker, yellow)                         -->
    <!-- ================================================================ -->

    <model name="launch_pad">
      <static>true</static>
      <pose>0 0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="pad">
          <geometry><box><size>3 3 0.03</size></box></geometry>
          <material>
            <ambient>0.85 0.75 0.0 1</ambient>
            <diffuse>0.85 0.75 0.0 1</diffuse>
            <emissive>0.2 0.15 0.0 1</emissive>
          </material>
        </visual>
        <collision name="col">
          <geometry><box><size>3 3 0.03</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- H cross-bar (horizontal) -->
    <model name="pad_h_bar">
      <static>true</static>
      <pose>0 0 0.06 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.4 0.35 0.02</size></box></geometry>
          <material>
            <ambient>0.0 0.0 0.0 1</ambient>
            <diffuse>0.0 0.0 0.0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- ROAD (north from pad toward building)                            -->
    <!-- ================================================================ -->

    <model name="road">
      <static>true</static>
      <pose>0 55 0.01 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>7 110 0.02</size></box></geometry>
          <material>
            <ambient>0.25 0.25 0.25 1</ambient>
            <diffuse>0.25 0.25 0.25 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Road centre line -->
    <model name="road_line">
      <static>true</static>
      <pose>0 55 0.03 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.2 110 0.01</size></box></geometry>
          <material>
            <ambient>0.9 0.9 0.9 1</ambient>
            <diffuse>0.9 0.9 0.9 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- MAIN TARGET BUILDING  (centre 0, 100, 6 — south face y=92.5)    -->
    <!-- 3 floors × 4 m = 12 m total.  Floor 2 = z 4→8.                 -->
    <!-- ================================================================ -->

    <!-- Building shell -->
    <model name="building_main">
      <static>true</static>
      <pose>0 100 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20 15 12</size></box></geometry>
          <material>
            <ambient>0.65 0.62 0.58 1</ambient>
            <diffuse>0.65 0.62 0.58 1</diffuse>
            <specular>0.08 0.08 0.08 1</specular>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>20 15 12</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- Roof parapet -->
    <model name="building_roof">
      <static>true</static>
      <pose>0 100 12.2 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20.4 15.4 0.4</size></box></geometry>
          <material>
            <ambient>0.35 0.35 0.35 1</ambient>
            <diffuse>0.35 0.35 0.35 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>20.4 15.4 0.4</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- Floor bands on south face -->
    <model name="floor_band_1">
      <static>true</static>
      <pose>0 92.48 4.05 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20.1 0.06 0.15</size></box></geometry>
          <material><ambient>0.28 0.28 0.28 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material>
        </visual>
      </link>
    </model>
    <model name="floor_band_2">
      <static>true</static>
      <pose>0 92.48 8.05 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>20.1 0.06 0.15</size></box></geometry>
          <material><ambient>0.28 0.28 0.28 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- WINDOWS — south facade                                           -->
    <!-- Dark glass on floors 1 & 3; fire window on floor 2 centre       -->
    <!-- Window size: 2.5 m wide × 2.2 m tall                           -->
    <!-- ================================================================ -->

    <!-- Floor 1 — left -->
    <model name="win_f1_l">
      <static>true</static>
      <pose>-6 92.46 2 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.5 0.04 2.2</size></box></geometry>
          <material>
            <ambient>0.08 0.12 0.18 1</ambient>
            <diffuse>0.08 0.12 0.18 1</diffuse>
            <specular>0.7 0.8 1.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor 1 — right -->
    <model name="win_f1_r">
      <static>true</static>
      <pose>6 92.46 2 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.5 0.04 2.2</size></box></geometry>
          <material>
            <ambient>0.08 0.12 0.18 1</ambient>
            <diffuse>0.08 0.12 0.18 1</diffuse>
            <specular>0.7 0.8 1.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor 2 — left (dark) -->
    <model name="win_f2_l">
      <static>true</static>
      <pose>-6 92.46 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.5 0.04 2.2</size></box></geometry>
          <material>
            <ambient>0.08 0.12 0.18 1</ambient>
            <diffuse>0.08 0.12 0.18 1</diffuse>
            <specular>0.7 0.8 1.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor 2 — right (dark) -->
    <model name="win_f2_r">
      <static>true</static>
      <pose>6 92.46 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.5 0.04 2.2</size></box></geometry>
          <material>
            <ambient>0.08 0.12 0.18 1</ambient>
            <diffuse>0.08 0.12 0.18 1</diffuse>
            <specular>0.7 0.8 1.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor 3 — left -->
    <model name="win_f3_l">
      <static>true</static>
      <pose>-6 92.46 10 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.5 0.04 2.2</size></box></geometry>
          <material>
            <ambient>0.08 0.12 0.18 1</ambient>
            <diffuse>0.08 0.12 0.18 1</diffuse>
            <specular>0.7 0.8 1.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Floor 3 — right -->
    <model name="win_f3_r">
      <static>true</static>
      <pose>6 92.46 10 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.5 0.04 2.2</size></box></geometry>
          <material>
            <ambient>0.08 0.12 0.18 1</ambient>
            <diffuse>0.08 0.12 0.18 1</diffuse>
            <specular>0.7 0.8 1.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- TARGET WINDOW — floor 2 centre — FIRE                           -->
    <!-- (0, 92.46, 6) — 3 m wide, 2.5 m tall                           -->
    <!-- ================================================================ -->

    <!-- Outer glass (orange glow seen from drone camera) -->
    <model name="fire_window_glass">
      <static>true</static>
      <pose>0 92.46 6 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>3.0 0.04 2.5</size></box></geometry>
          <material>
            <ambient>1.0 0.35 0.02 1</ambient>
            <diffuse>1.0 0.35 0.02 1</diffuse>
            <emissive>0.9 0.25 0.0 1</emissive>
            <specular>1.0 0.6 0.1 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <!-- Inner fire — bright orange body -->
    <model name="fire_inner">
      <static>true</static>
      <pose>0 93.1 6.0 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>1.8 0.04 1.8</size></box></geometry>
          <material>
            <ambient>1.0 0.55 0.0 1</ambient>
            <diffuse>1.0 0.55 0.0 1</diffuse>
            <emissive>1.0 0.55 0.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- Fire core — red-hot base -->
    <model name="fire_core">
      <static>true</static>
      <pose>0 93.2 5.1 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>1.0 0.04 0.7</size></box></geometry>
          <material>
            <ambient>1.0 0.08 0.0 1</ambient>
            <diffuse>1.0 0.08 0.0 1</diffuse>
            <emissive>1.0 0.08 0.0 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- Smoke (dark grey panel above fire) -->
    <model name="fire_smoke">
      <static>true</static>
      <pose>0 93.0 7.3 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>2.2 0.04 0.6</size></box></geometry>
          <material>
            <ambient>0.25 0.25 0.25 0.7</ambient>
            <diffuse>0.25 0.25 0.25 0.7</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- PEOPLE — 3 occupants visible through the fire window            -->
    <!--                                                                  -->
    <!-- All stand on floor 2 (z=4). For camera visibility the body      -->
    <!-- centre sits at z=5.5 and head at z=6.6, which falls inside      -->
    <!-- the fire window range z=4.75–7.25.                              -->
    <!-- ================================================================ -->

    <!-- Person 1 — left, blue jacket -->
    <model name="person1_body">
      <static>true</static>
      <pose>-0.9 93.4 5.5 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.48 0.28 1.6</size></box></geometry>
          <material>
            <ambient>0.10 0.20 0.75 1</ambient>
            <diffuse>0.10 0.20 0.75 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    <model name="person1_head">
      <static>true</static>
      <pose>-0.9 93.4 6.55 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><sphere><radius>0.17</radius></sphere></geometry>
          <material>
            <ambient>0.80 0.60 0.42 1</ambient>
            <diffuse>0.80 0.60 0.42 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Person 2 — right, red jacket -->
    <model name="person2_body">
      <static>true</static>
      <pose>0.9 93.4 5.5 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.48 0.28 1.6</size></box></geometry>
          <material>
            <ambient>0.78 0.10 0.10 1</ambient>
            <diffuse>0.78 0.10 0.10 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    <model name="person2_head">
      <static>true</static>
      <pose>0.9 93.4 6.55 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><sphere><radius>0.17</radius></sphere></geometry>
          <material>
            <ambient>0.72 0.52 0.38 1</ambient>
            <diffuse>0.72 0.52 0.38 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Person 3 — centre-back, crouching (green, lower body centre) -->
    <model name="person3_body">
      <static>true</static>
      <pose>0.05 94.0 5.1 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>0.48 0.28 1.0</size></box></geometry>
          <material>
            <ambient>0.12 0.58 0.18 1</ambient>
            <diffuse>0.12 0.58 0.18 1</diffuse>
          </material>
        </visual>
      </link>
    </model>
    <model name="person3_head">
      <static>true</static>
      <pose>0.05 94.0 5.75 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><sphere><radius>0.17</radius></sphere></geometry>
          <material>
            <ambient>0.65 0.48 0.30 1</ambient>
            <diffuse>0.65 0.48 0.30 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================ -->
    <!-- SURROUNDING ENVIRONMENT                                           -->
    <!-- ================================================================ -->

    <!-- Secondary building — east side -->
    <model name="building_east">
      <static>true</static>
      <pose>35 110 5 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>14 18 10</size></box></geometry>
          <material>
            <ambient>0.60 0.58 0.54 1</ambient>
            <diffuse>0.60 0.58 0.54 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>14 18 10</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- Small garage / shed — west -->
    <model name="building_west">
      <static>true</static>
      <pose>-30 90 2.5 0 0 0</pose>
      <link name="link">
        <visual name="v">
          <geometry><box><size>10 12 5</size></box></geometry>
          <material>
            <ambient>0.55 0.50 0.45 1</ambient>
            <diffuse>0.55 0.50 0.45 1</diffuse>
          </material>
        </visual>
        <collision name="c">
          <geometry><box><size>10 12 5</size></box></geometry>
        </collision>
      </link>
    </model>

    <!-- Trees -->
    <model name="tree1_trunk">
      <static>true</static><pose>18 40 3 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><cylinder><radius>0.3</radius><length>6</length></cylinder></geometry>
        <material><ambient>0.35 0.25 0.10 1</ambient><diffuse>0.35 0.25 0.10 1</diffuse></material></visual></link>
    </model>
    <model name="tree1_crown">
      <static>true</static><pose>18 40 7.5 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><sphere><radius>2.8</radius></sphere></geometry>
        <material><ambient>0.12 0.45 0.12 1</ambient><diffuse>0.12 0.45 0.12 1</diffuse></material></visual></link>
    </model>

    <model name="tree2_trunk">
      <static>true</static><pose>-22 55 3 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><cylinder><radius>0.3</radius><length>6</length></cylinder></geometry>
        <material><ambient>0.35 0.25 0.10 1</ambient><diffuse>0.35 0.25 0.10 1</diffuse></material></visual></link>
    </model>
    <model name="tree2_crown">
      <static>true</static><pose>-22 55 7.5 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><sphere><radius>2.5</radius></sphere></geometry>
        <material><ambient>0.12 0.45 0.12 1</ambient><diffuse>0.12 0.45 0.12 1</diffuse></material></visual></link>
    </model>

    <model name="tree3_trunk">
      <static>true</static><pose>25 75 3 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><cylinder><radius>0.28</radius><length>6</length></cylinder></geometry>
        <material><ambient>0.35 0.25 0.10 1</ambient><diffuse>0.35 0.25 0.10 1</diffuse></material></visual></link>
    </model>
    <model name="tree3_crown">
      <static>true</static><pose>25 75 7.5 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><sphere><radius>2.6</radius></sphere></geometry>
        <material><ambient>0.10 0.42 0.10 1</ambient><diffuse>0.10 0.42 0.10 1</diffuse></material></visual></link>
    </model>

    <!-- ================================================================ -->
    <!-- MISSION WAYPOINT GROUND MARKERS (cyan spheres)                  -->
    <!-- WP1=pad, WP2=40m, WP3=survey hover at (0,70,0), WP4=RTH       -->
    <!-- ================================================================ -->

    <model name="wp1_marker">
      <static>true</static><pose>0 0 0.3 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><sphere><radius>0.25</radius></sphere></geometry>
        <material><ambient>0.0 0.9 0.9 1</ambient><diffuse>0.0 0.9 0.9 1</diffuse><emissive>0.0 0.4 0.4 1</emissive></material></visual></link>
    </model>

    <model name="wp2_marker">
      <static>true</static><pose>0 40 0.3 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><sphere><radius>0.25</radius></sphere></geometry>
        <material><ambient>0.0 0.9 0.9 1</ambient><diffuse>0.0 0.9 0.9 1</diffuse><emissive>0.0 0.4 0.4 1</emissive></material></visual></link>
    </model>

    <!-- Survey hover point: drone hovers here at ~15 m altitude looking at fire window -->
    <model name="wp3_survey_marker">
      <static>true</static><pose>0 70 0.3 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><sphere><radius>0.35</radius></sphere></geometry>
        <material><ambient>0.9 0.6 0.0 1</ambient><diffuse>0.9 0.6 0.0 1</diffuse><emissive>0.5 0.3 0.0 1</emissive></material></visual></link>
    </model>

    <!-- ================================================================ -->
    <!-- SPHERICAL COORDINATES — Nokia Arena, Tampere, Finland           -->
    <!-- ================================================================ -->

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>61.4938</latitude_deg>
      <longitude_deg>23.7735</longitude_deg>
      <elevation>77.0</elevation>
      <heading_deg>0.0</heading_deg>
    </spherical_coordinates>

    <gravity>0.0 0.0 -9.81</gravity>

  </world>
</sdf>
