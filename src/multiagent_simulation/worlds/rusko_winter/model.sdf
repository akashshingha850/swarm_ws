<?xml version="1.0"?>
<sdf version="1.9">
  <world name="map">
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>2.0</real_time_factor>
      <real_time_update_rate>0</real_time_update_rate>
    </physics>

    <light name='sunUTC' type='directional'>
      <pose>0 0 500 0 -0 0</pose>
      <cast_shadows>false</cast_shadows>
      <intensity>0.8</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.8 0.85 0.9 1</diffuse>
      <specular>0.3 0.35 0.4 1</specular>
      <attenuation>
        <range>2000</range>
        <linear>0</linear>
        <constant>1</constant>
        <quadratic>0</quadratic>
      </attenuation>
    </light>

    <plugin name='gz::sim::systems::Physics' filename='gz-sim-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands' filename='gz-sim-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='gz-sim-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact' filename='gz-sim-contact-system'/>
    <plugin name='gz::sim::systems::Imu' filename='gz-sim-imu-system'/>
    <plugin name='gz::sim::systems::AirPressure' filename='gz-sim-air-pressure-system'/>
    <plugin name='gz::sim::systems::AirSpeed' filename='gz-sim-air-speed-system'/>
    <plugin name='gz::sim::systems::ApplyLinkWrench' filename='gz-sim-apply-link-wrench-system'/>
    <plugin name='gz::sim::systems::Magnetometer' filename='gz-sim-magnetometer-system'/>
    <plugin name='gz::sim::systems::NavSat' filename='gz-sim-navsat-system'/>
    <plugin name='gz::sim::systems::Sensors' filename='gz-sim-sensors-system'>
      <render_engine>ogre2</render_engine>
    </plugin>

    <scene>
      <ambient>0.5 0.55 0.6</ambient>
      <sky></sky>
    </scene>

    <model name="ground_plane">
      <static>true</static>
      <pose>0 0 -1 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>2000 2000 0.1</size>
            </box>
          </geometry>
        </collision>
      </link>
    </model>

    <model name="rusko_winter">
      <static>true</static>
      <!-- <pose>0 0 -1 0 0 0</pose> -->
      <pose>70 0 -32 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <cast_shadows>false</cast_shadows>
          <geometry>
            <mesh>
              <uri>rusko_winter_visual.glb</uri>
            </mesh>
          </geometry>
        </visual>
        <collision name="collision">
          <geometry>
            <mesh>
              <uri>rusko_winter_visual.glb</uri>
            </mesh>
          </geometry>
        </collision>
      </link>
    </model>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>65.05066251893697</latitude_deg>
      <longitude_deg>25.52583096586382</longitude_deg>
      <elevation>10.0</elevation>
      <heading_deg>0.0</heading_deg>
    </spherical_coordinates>
    <gravity>0.0 0.0 -9.81</gravity>
  </world>
</sdf>

